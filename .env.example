# ==========================================
# Sylvi Environment Variables Template
# Copy this file to '.env' and fill in your keys.
# ==========================================

# --- LLM Providers ---
# Gemini API Keys (comma-separated list for load balancing)
# Example: GEMINI_API_KEYS=key1,key2,key3
GEMINI_API_KEYS=your_gemini_api_key_here

# Groq API Keys (comma-separated list for load balancing)
# Example: GROQ_API_KEYS=key1,key2,key3
GROQ_API_KEYS=your_groq_api_key_here

# --- Model Selections ---
GROQ_TEXT_MODEL=llama-3.3-70b-versatile
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_WHISPER_MODEL=whisper-large-v3-turbo
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-001

# --- Vector Database ---
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=sylvi-memory

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# --- Application Configuration ---
# Options: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
DATABASE_URL=postgresql://username:password@hostname:port/database

# --- LangSmith Telemetry ---
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT="Sylvi"
