# ==========================================
# Sylvi Environment Variables Template
# Copy this file to '.env' and fill in your keys.
# ==========================================

# --- LLM Providers ---
# Gemini API Keys (comma-separated list for load balancing)
# Example: GEMINI_API_KEYS=key1,key2,key3
GEMINI_API_KEYS=your_gemini_api_key_here

# Groq API Keys (comma-separated list for load balancing)
# Example: GROQ_API_KEYS=key1,key2,key3
GROQ_API_KEYS=your_groq_api_key_here

# --- Vector Database ---
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=sylvi-memory

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# --- Application Configuration ---
# Options: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
DATABASE_PATH=data/sylvi_profile.db
